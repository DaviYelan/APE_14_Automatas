# =============================================================
# .env.example — Mini-Compilador NLP-Math
# Copia este archivo a ".env" y ajusta si es necesario.
# =============================================================

# --- Ollama (LLM local) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=30

# --- Backend Flask (Python) ---
BACKEND_PORT=8000
LLM_MAX_WORKERS=4

# --- Servicio Semántico (Java / Spring Boot) ---
# Puerto del microservicio de análisis semántico
SEMANTIC_PORT=8080
# URL que Flask usa para llamar al servicio Java (dentro de Docker)
# En Docker usa el nombre de servicio; fuera de Docker usa localhost
SEMANTIC_SERVICE_URL=http://semantic:8080
# Timeout (seg) para que Flask espere la respuesta del servicio Java
SEMANTIC_TIMEOUT_SECONDS=30

# --- Frontend React + Vite ---
# URL que el NAVEGADOR usa para alcanzar el backend Flask
FRONTEND_PORT=3000
VITE_BACKEND_URL=http://localhost:8000

# --- Volumen Docker para modelos Ollama ---
OLLAMA_VOLUME_NAME=ollama_data
